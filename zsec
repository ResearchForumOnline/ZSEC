#!/usr/bin/env bash
set -euo pipefail

ZSEC_VERSION="0.1.0"
CONFIG_DIR="${ZSEC_CONFIG_DIR:-/etc/zsec}"
CONFIG_FILE="${CONFIG_DIR}/zsec.conf"
ALLOWLIST_DIR="${CONFIG_DIR}/allowlist.d"
STATE_DIR="${ZSEC_STATE_DIR:-/var/lib/zsec}"
LOG_DIR="${ZSEC_LOG_DIR:-/var/log/zsec}"
BACKUP_DIR="${ZSEC_BACKUP_DIR:-/var/backups/zsec}"
LOG_FILE="${LOG_DIR}/zsec.log"

ZSEC_APPLY_SYSCTL="${ZSEC_APPLY_SYSCTL:-1}"
ZSEC_DISABLE_UNPRIVILEGED_USERNS="${ZSEC_DISABLE_UNPRIVILEGED_USERNS:-auto}"
ZSEC_ENABLE_FAIL2BAN="${ZSEC_ENABLE_FAIL2BAN:-1}"
ZSEC_FIREWALL_GUARD="${ZSEC_FIREWALL_GUARD:-0}"
ZSEC_AI_AUDIT="${ZSEC_AI_AUDIT:-1}"
ZSEC_ADVISORY_FEED="${ZSEC_ADVISORY_FEED:-1}"
ZSEC_ADVISORY_FEED_URL="${ZSEC_ADVISORY_FEED_URL:-https://talktoai.org/zsec/feed.json}"
ZSEC_ADVISORY_TIMEOUT="${ZSEC_ADVISORY_TIMEOUT:-15}"
ZSEC_ADVISORY_MAX_ITEMS="${ZSEC_ADVISORY_MAX_ITEMS:-80}"
ZSEC_TAMPER_LOCK="${ZSEC_TAMPER_LOCK:-0}"
ZSEC_MIN_FREE_MB="${ZSEC_MIN_FREE_MB:-512}"

DRY_RUN=0
COMMAND="${1:-run}"
if [ "$COMMAND" = "--dry-run" ]; then
  DRY_RUN=1
  COMMAND="${2:-check}"
fi
if [ "$COMMAND" = "check" ]; then
  DRY_RUN=1
fi

mkdir -p "$CONFIG_DIR" "$ALLOWLIST_DIR" "$STATE_DIR" "$LOG_DIR" "$BACKUP_DIR"
touch "$LOG_FILE"
chmod 0750 "$CONFIG_DIR" "$STATE_DIR" "$LOG_DIR" "$BACKUP_DIR" 2>/dev/null || true
chmod 0640 "$LOG_FILE" 2>/dev/null || true

# shellcheck disable=SC1090
[ -f "$CONFIG_FILE" ] && . "$CONFIG_FILE"
for extra in "$ALLOWLIST_DIR"/*.conf; do
  [ -e "$extra" ] || continue
  # shellcheck disable=SC1090
  . "$extra"
done

ADVISORY_FEED_CACHE="${STATE_DIR}/advisory-feed.json"
ADVISORY_TODO_JSON="${STATE_DIR}/todo.json"
ADVISORY_TODO_TEXT="${STATE_DIR}/todo.txt"

log() {
  local level="$1"
  shift
  printf '%s level=%s msg="%s"\n' "$(date -Is)" "$level" "$*" | tee -a "$LOG_FILE" >/dev/null
}

info() { log "info" "$*"; }
warn() { log "warn" "$*"; }
fail() { log "error" "$*"; exit 1; }

need_root() {
  if [ "${EUID:-$(id -u)}" -ne 0 ]; then
    fail "ZSEC must run as root"
  fi
}

have() { command -v "$1" >/dev/null 2>&1; }

is_active_unit() {
  have systemctl && systemctl is-active "$1" >/dev/null 2>&1
}

container_or_virtualization_host() {
  have docker && return 0
  have podman && return 0
  have kubelet && return 0
  have pveversion && return 0
  have pct && return 0
  is_active_unit lxc && return 0
  is_active_unit pve-cluster && return 0
  is_active_unit kubelet && return 0
  [ -d /etc/pve ] && return 0
  [ -d /var/lib/lxc ] && return 0
  return 1
}

os_id() {
  # shellcheck disable=SC1091
  . /etc/os-release
  printf '%s\n' "${ID:-unknown}"
}

os_like() {
  # shellcheck disable=SC1091
  . /etc/os-release
  printf '%s %s\n' "${ID:-unknown}" "${ID_LIKE:-}"
}

is_debian_like() {
  os_like | grep -Eq '(^| )(ubuntu|debian)( |$)'
}

is_rhel_like() {
  os_like | grep -Eq '(^| )(rhel|fedora|centos|almalinux|rocky)( |$)'
}

active_admin_ip() {
  if [ -n "${ZSEC_ADMIN_IP:-}" ]; then
    printf '%s\n' "$ZSEC_ADMIN_IP"
  elif [ -n "${SSH_CONNECTION:-}" ]; then
    printf '%s\n' "$SSH_CONNECTION" | awk '{print $1}'
  fi
}

ssh_port() {
  if have sshd; then
    sshd -T 2>/dev/null | awk '/^port /{print $2; exit}' || true
  else
    awk 'tolower($1)=="port"{print $2; exit}' /etc/ssh/sshd_config 2>/dev/null || true
  fi
}

free_mb_for() {
  df -Pm "$1" | awk 'NR==2{print $4}'
}

preflight() {
  need_root
  local free_root
  free_root="$(free_mb_for /)"
  if [ "${free_root:-0}" -lt "$ZSEC_MIN_FREE_MB" ]; then
    fail "not enough free disk on / (${free_root} MB free, need ${ZSEC_MIN_FREE_MB} MB)"
  fi

  if is_debian_like && pgrep -x apt >/dev/null 2>&1; then
    fail "apt is already running"
  fi
  if is_rhel_like && pgrep -x dnf >/dev/null 2>&1; then
    fail "dnf is already running"
  fi
}

backup_file() {
  local path="$1"
  local stamp="$2"
  [ -e "$path" ] || return 0
  local dest="${BACKUP_DIR}/${stamp}${path}"
  mkdir -p "$(dirname "$dest")"
  cp -a "$path" "$dest"
}

lockout_guard() {
  need_root
  if [ "$DRY_RUN" = "1" ]; then
    local dry_ip
    dry_ip="$(active_admin_ip || true)"
    info "dry-run: would back up SSH config and authorized_keys"
    [ -n "$dry_ip" ] && info "dry-run: would record admin SSH IP ${dry_ip}"
    return 0
  fi

  local stamp
  stamp="$(date +%Y%m%d-%H%M%S)"
  backup_file /etc/ssh/sshd_config "$stamp"
  backup_file /root/.ssh/authorized_keys "$stamp"
  for key_file in /home/*/.ssh/authorized_keys; do
    [ -e "$key_file" ] || continue
    backup_file "$key_file" "$stamp"
  done

  local ip
  ip="$(active_admin_ip || true)"
  if [ -n "$ip" ]; then
    printf 'ZSEC_ADMIN_IP="%s"\n' "$ip" > "${ALLOWLIST_DIR}/admin-ip.conf"
    chmod 0600 "${ALLOWLIST_DIR}/admin-ip.conf"
    info "recorded admin SSH IP ${ip}"
  fi

  if [ ! -s /root/.ssh/authorized_keys ] && ! find /home -maxdepth 3 -path '*/.ssh/authorized_keys' -size +0c 2>/dev/null | grep -q .; then
    warn "no authorized_keys files found; avoid SSH changes until key login is confirmed"
  fi
}

firewall_guard() {
  [ "$ZSEC_FIREWALL_GUARD" = "1" ] || return 0
  local ip port
  ip="$(active_admin_ip || true)"
  port="$(ssh_port || true)"
  port="${port:-22}"
  [ -n "$ip" ] || { warn "firewall guard enabled but no admin IP detected"; return 0; }

  if have ufw && ufw status 2>/dev/null | grep -qi '^Status: active'; then
    if [ "$DRY_RUN" = "1" ]; then
      info "dry-run: would allow SSH from ${ip} on ufw port ${port}"
    else
      ufw allow from "$ip" to any port "$port" proto tcp comment "ZSEC admin SSH guard" >/dev/null || true
      info "ufw admin SSH allow rule checked for ${ip}:${port}"
    fi
  elif have firewall-cmd && systemctl is-active firewalld >/dev/null 2>&1; then
    if [ "$DRY_RUN" = "1" ]; then
      info "dry-run: would add firewalld SSH rich rule for ${ip}"
    else
      firewall-cmd --permanent --add-rich-rule="rule family='ipv4' source address='${ip}' port port='${port}' protocol='tcp' accept" >/dev/null || true
      firewall-cmd --reload >/dev/null || true
      info "firewalld admin SSH allow rule checked for ${ip}:${port}"
    fi
  else
    info "no active supported firewall detected for guard rule"
  fi
}

write_sysctl_hardening() {
  [ "$ZSEC_APPLY_SYSCTL" = "1" ] || return 0
  local out="/etc/sysctl.d/90-zsec-hardening.conf"
  local userns_line=""

  if [ "$ZSEC_DISABLE_UNPRIVILEGED_USERNS" = "1" ]; then
    userns_line="kernel.unprivileged_userns_clone = 0"
  elif [ "$ZSEC_DISABLE_UNPRIVILEGED_USERNS" = "auto" ]; then
    if ! container_or_virtualization_host; then
      userns_line="kernel.unprivileged_userns_clone = 0"
    else
      info "preserving unprivileged user namespaces on container/virtualization host"
    fi
  fi

  if [ "$DRY_RUN" = "1" ]; then
    info "dry-run: would write sysctl hardening to ${out}"
    return 0
  fi

  cat > "$out" <<EOF
# Managed by ZSEC Auto Updates.
kernel.kptr_restrict = 2
kernel.dmesg_restrict = 1
kernel.yama.ptrace_scope = 1
kernel.unprivileged_bpf_disabled = 1
fs.protected_hardlinks = 1
fs.protected_symlinks = 1
fs.protected_fifos = 2
fs.protected_regular = 2
net.ipv4.tcp_syncookies = 1
net.ipv4.conf.all.rp_filter = 1
net.ipv4.conf.default.rp_filter = 1
${userns_line}
EOF
  sysctl --system >/dev/null || warn "sysctl reload reported warnings"
  info "sysctl hardening applied"
}

configure_fail2ban() {
  [ "$ZSEC_ENABLE_FAIL2BAN" = "1" ] || return 0
  local admin_ip ignore_line=""
  admin_ip="$(active_admin_ip || true)"
  [ -n "$admin_ip" ] && ignore_line="ignoreip = 127.0.0.1/8 ::1 ${admin_ip}"

  if ! have fail2ban-server; then
    if is_debian_like && have apt-get; then
      if [ "$DRY_RUN" = "1" ]; then
        info "dry-run: would install fail2ban"
        return 0
      fi
      apt-get update -y >/dev/null
      DEBIAN_FRONTEND=noninteractive apt-get install -y fail2ban >/dev/null || { warn "fail2ban install failed"; return 0; }
    else
      warn "fail2ban not installed; on Alma/Rocky install it from an approved repo before enabling this jail"
      return 0
    fi
  fi

  if [ "$DRY_RUN" = "1" ]; then
    info "dry-run: would configure fail2ban sshd jail"
    return 0
  fi

  mkdir -p /etc/fail2ban/jail.d
  cat > /etc/fail2ban/jail.d/zsec-sshd.conf <<EOF
[sshd]
enabled = true
backend = systemd
maxretry = 5
findtime = 10m
bantime = 1h
${ignore_line}
EOF
  systemctl enable --now fail2ban >/dev/null 2>&1 || true
  systemctl restart fail2ban >/dev/null 2>&1 || true
  info "fail2ban sshd jail configured"
}

debian_security_package_list() {
  python3 <<'PY'
import sys

try:
    import apt
except Exception as exc:
    print(f"python-apt unavailable: {exc}", file=sys.stderr)
    sys.exit(3)

cache = apt.Cache()
cache.open(None)
selected = []

for pkg in cache:
    if not pkg.is_installed or not pkg.is_upgradable:
        continue
    candidate = pkg.candidate
    if not candidate:
        continue
    for origin in candidate.origins:
        archive = (origin.archive or "").lower()
        label = (origin.label or "").lower()
        site = (origin.site or "").lower()
        origin_name = (origin.origin or "").lower()
        if "security" in archive or "security" in label or ("esm" in origin_name and "security" in archive):
            selected.append(pkg.name)
            break

for name in sorted(set(selected)):
    print(name)
PY
}

security_updates_debian() {
  apt-get update -y >/dev/null
  local packages=()
  if ! mapfile -t packages < <(debian_security_package_list); then
    warn "python-apt security package selection failed; not applying apt upgrades"
    return 0
  fi

  if [ "${#packages[@]}" -eq 0 ]; then
    info "no apt security packages pending"
    return 0
  fi

  if [ "$DRY_RUN" = "1" ]; then
    info "dry-run: apt security packages pending: ${packages[*]}"
  else
    DEBIAN_FRONTEND=noninteractive apt-get install --only-upgrade -y "${packages[@]}"
  fi
}

security_updates_rhel() {
  have dnf || fail "dnf not found on RHEL-like system"
  if [ "$DRY_RUN" = "1" ]; then
    dnf -q updateinfo list security updates || true
    info "dry-run: security update check completed"
  else
    dnf -y --security upgrade --setopt=install_weak_deps=False || warn "dnf security upgrade reported issues"
  fi
}

ai_surface_audit() {
  [ "$ZSEC_AI_AUDIT" = "1" ] || return 0
  have ss || { warn "ss not found; skipping local AI surface audit"; return 0; }
  local findings
  findings="$(ss -H -lntup 2>/dev/null | awk '
    {
      local_addr = $5
      if (local_addr ~ /(127\.0\.0\.1|\[::1\]|::1|localhost):/) {
        next
      }
      if (local_addr ~ /:(11434|3000|7860|8888|5000|8000|8080|8090|8501)$/) {
        print
      }
    }
  ' || true)"
  if [ -n "$findings" ]; then
    warn "public AI/dev-like service ports detected; review bindings"
    printf '%s\n' "$findings" >> "$LOG_FILE"
  else
    info "AI/dev service exposure audit passed"
  fi
}

advisory_feed_check() {
  [ "$ZSEC_ADVISORY_FEED" = "1" ] || return 0
  have python3 || { warn "python3 not found; skipping advisory feed"; return 0; }

  local tmp_feed
  tmp_feed="${ADVISORY_FEED_CACHE}.tmp"
  if have curl; then
    if curl --proto '=https' --tlsv1.2 -fsSL --connect-timeout "$ZSEC_ADVISORY_TIMEOUT" --max-time "$ZSEC_ADVISORY_TIMEOUT" "$ZSEC_ADVISORY_FEED_URL" -o "$tmp_feed"; then
      mv "$tmp_feed" "$ADVISORY_FEED_CACHE"
      chmod 0640 "$ADVISORY_FEED_CACHE" 2>/dev/null || true
      info "advisory feed refreshed from ${ZSEC_ADVISORY_FEED_URL}"
    else
      rm -f "$tmp_feed"
      warn "advisory feed refresh failed; using cached feed if available"
    fi
  else
    warn "curl not found; using cached advisory feed if available"
  fi

  [ -s "$ADVISORY_FEED_CACHE" ] || { warn "no advisory feed cache available"; return 0; }

  local result
  if ! result="$(python3 - "$ADVISORY_FEED_CACHE" "$ADVISORY_TODO_JSON" "$ADVISORY_TODO_TEXT" "$ZSEC_ADVISORY_MAX_ITEMS" <<'PY'
import datetime
import json
import os
import re
import subprocess
import sys

feed_path, todo_json_path, todo_text_path, max_items_raw = sys.argv[1:5]

try:
    max_items = max(1, min(int(max_items_raw), 250))
except Exception:
    max_items = 80

def read_os_release():
    data = {}
    try:
        with open("/etc/os-release", "r", encoding="utf-8", errors="replace") as fh:
            for line in fh:
                line = line.strip()
                if not line or "=" not in line:
                    continue
                key, value = line.split("=", 1)
                data[key] = value.strip().strip('"')
    except OSError:
        pass
    return data

def command_lines(command):
    try:
        out = subprocess.check_output(command, stderr=subprocess.DEVNULL)
    except Exception:
        return []
    return out.decode("utf-8", "replace").splitlines()

def installed_packages():
    names = set()
    for line in command_lines(["dpkg-query", "-W", "-f=${binary:Package}\n"]):
        line = line.strip().lower()
        if line:
            names.add(line.split(":")[0])
    for line in command_lines(["rpm", "-qa", "--qf", "%{NAME}\n"]):
        line = line.strip().lower()
        if line:
            names.add(line)
    return names

def public_ports():
    ports = set()
    for line in command_lines(["ss", "-H", "-lntup"]):
        parts = line.split()
        if len(parts) < 5:
            continue
        local_addr = parts[4]
        if re.search(r"(127\.0\.0\.1|\[::1\]|::1|localhost):", local_addr):
            continue
        match = re.search(r":(\d+)$", local_addr)
        if match:
            ports.add(match.group(1))
    return ports

def text_blob(item):
    values = [
        item.get("id", ""),
        item.get("title", ""),
        item.get("summary", ""),
    ]
    values.extend(item.get("tags") or [])
    affected = item.get("affected") or {}
    for key in ("vendors", "products", "keywords"):
        values.extend(affected.get(key) or [])
    return " ".join(str(value).lower() for value in values if value)

def has_any(blob, words):
    return any(word in blob for word in words)

try:
    with open(feed_path, "r", encoding="utf-8", errors="replace") as fh:
        feed = json.load(fh)
except Exception as exc:
    print("invalid advisory feed: %s" % exc)
    sys.exit(2)

if feed.get("schema") != "zsec.feed.v1" or not isinstance(feed.get("items"), list):
    print("invalid advisory feed schema")
    sys.exit(2)

os_release = read_os_release()
os_words = " ".join([
    os_release.get("ID", ""),
    os_release.get("ID_LIKE", ""),
    os_release.get("NAME", ""),
    os_release.get("VERSION_ID", ""),
]).lower()
packages = installed_packages()
ports = public_ports()
kernel_release = command_lines(["uname", "-r"])
kernel_release = kernel_release[0] if kernel_release else ""

package_markers = {
    "ssh": ["openssh-server", "openssh-client", "openssh", "sshd"],
    "openssh": ["openssh-server", "openssh-client", "openssh", "sshd"],
    "apache": ["apache2", "httpd"],
    "httpd": ["apache2", "httpd"],
    "nginx": ["nginx"],
    "php": ["php", "php-fpm"],
    "openssl": ["openssl", "libssl3", "openssl-libs"],
    "curl": ["curl", "libcurl4", "libcurl"],
    "sudo": ["sudo"],
    "systemd": ["systemd"],
    "docker": ["docker", "docker-ce"],
    "podman": ["podman"],
    "proxmox": ["pve-manager", "proxmox-ve"],
    "kernel": ["linux-image", "kernel", "kernel-core", "pve-kernel"],
    "node": ["nodejs", "node"],
    "ollama": ["ollama"],
}

os_markers = {
    "ubuntu": "ubuntu" in os_words,
    "debian": "debian" in os_words,
    "almalinux": "almalinux" in os_words or "rhel" in os_words,
    "rocky": "rocky" in os_words or "rhel" in os_words,
    "rhel": "rhel" in os_words or "fedora" in os_words,
    "linux": True,
}

matches = []
watch = 0

for item in feed.get("items", [])[:max_items]:
    if not isinstance(item, dict):
        continue
    blob = text_blob(item)
    reasons = []

    for marker, enabled in os_markers.items():
        if enabled and marker in blob:
            reasons.append("matches OS family: %s" % marker)

    for marker, package_names in package_markers.items():
        if marker in blob and any(pkg in packages for pkg in package_names):
            reasons.append("related installed package/service: %s" % marker)

    if has_any(blob, ["linux kernel", "kernel privilege", "kernel flaw"]) and kernel_release:
        reasons.append("kernel-related advisory for running kernel %s" % kernel_release)

    if has_any(blob, ["ai service", "ollama", "jupyter", "gradio", "open webui", "dev service"]):
        exposed = sorted(ports.intersection({"11434", "3000", "7860", "8888", "5000", "8000", "8080", "8090", "8501"}))
        if exposed:
            reasons.append("public AI/dev-like port(s): %s" % ", ".join(exposed))

    severity = str(item.get("severity", "info")).lower()
    if reasons:
        matches.append({
            "id": item.get("id", "unknown"),
            "severity": severity,
            "kind": item.get("kind", "advisory"),
            "title": item.get("title", "Untitled advisory"),
            "source_url": (item.get("source") or {}).get("url", ""),
            "published": item.get("published", ""),
            "reason": "; ".join(sorted(set(reasons))),
            "action": item.get("zsec_action", "Review and apply vendor security updates if affected."),
        })
    elif severity in ("critical", "high") or item.get("kind") == "vulnerability":
        watch += 1

severity_order = {"critical": 0, "high": 1, "medium": 2, "low": 3, "info": 4}
matches = sorted(matches, key=lambda row: (severity_order.get(row.get("severity"), 5), row.get("published", "")))[:50]

summary = {
    "generated_at": datetime.datetime.now(datetime.timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z"),
    "feed_generated_at": feed.get("generated_at", ""),
    "feed_url": feed.get("home_url", ""),
    "local_os": os_release.get("PRETTY_NAME", os_words),
    "matches": matches,
    "watch_count": watch,
    "policy": "Read-only feed. ZSEC never executes commands from feed data.",
}

with open(todo_json_path, "w", encoding="utf-8") as fh:
    json.dump(summary, fh, indent=2, sort_keys=True)
    fh.write("\n")

lines = [
    "ZSEC advisory TODOs",
    "Generated: %s" % summary["generated_at"],
    "Policy: %s" % summary["policy"],
    "Local OS: %s" % summary["local_os"],
    "",
]
if not matches:
    lines.append("No locally relevant feed TODOs found.")
else:
    for idx, item in enumerate(matches, 1):
        lines.append("%d. [%s] %s" % (idx, item.get("severity", "info").upper(), item.get("title", "Untitled advisory")))
        if item.get("reason"):
            lines.append("   Reason: %s" % item["reason"])
        if item.get("action"):
            lines.append("   Action: %s" % item["action"])
        if item.get("source_url"):
            lines.append("   Source: %s" % item["source_url"])
        lines.append("")
if watch:
    lines.append("Additional high-priority feed items kept on watch: %s" % watch)

with open(todo_text_path, "w", encoding="utf-8") as fh:
    fh.write("\n".join(lines).rstrip() + "\n")

print("matched=%d watch=%d feed_items=%d" % (len(matches), watch, len(feed.get("items", []))))
PY
)"; then
    warn "advisory feed processing failed: ${result}"
    return 0
  fi
  chmod 0640 "$ADVISORY_TODO_JSON" "$ADVISORY_TODO_TEXT" 2>/dev/null || true
  info "advisory feed processed; ${result}"
}

tamper_lock_notice() {
  if [ "$ZSEC_TAMPER_LOCK" = "1" ]; then
    if have chattr; then
      if [ "$DRY_RUN" = "1" ]; then
        info "dry-run: would set immutable bit on /usr/local/sbin/zsec and ${CONFIG_FILE}"
      else
        chattr +i /usr/local/sbin/zsec "$CONFIG_FILE" 2>/dev/null || warn "immutable lock failed"
      fi
    else
      warn "chattr not available for tamper lock"
    fi
  fi
}

run_updates() {
  preflight
  lockout_guard
  firewall_guard
  write_sysctl_hardening
  configure_fail2ban
  ai_surface_audit
  advisory_feed_check

  if is_debian_like; then
    security_updates_debian
  elif is_rhel_like; then
    security_updates_rhel
  else
    fail "unsupported OS: $(os_id)"
  fi

  tamper_lock_notice
  info "ZSEC run completed; dry_run=${DRY_RUN}"
}

status() {
  printf 'ZSEC Auto Updates %s\n' "$ZSEC_VERSION"
  printf 'Config: %s\n' "$CONFIG_FILE"
  printf 'Log: %s\n' "$LOG_FILE"
  if have systemctl; then
    systemctl --no-pager --full status zsec.timer 2>/dev/null || true
  fi
  printf '\nLatest log:\n'
  tail -n 40 "$LOG_FILE" 2>/dev/null || true
  if [ -s "$ADVISORY_TODO_TEXT" ]; then
    printf '\nLatest advisory TODOs:\n'
    sed -n '1,80p' "$ADVISORY_TODO_TEXT" 2>/dev/null || true
  fi
}

audit_only() {
  preflight
  lockout_guard
  firewall_guard
  write_sysctl_hardening
  configure_fail2ban
  ai_surface_audit
  advisory_feed_check
  info "ZSEC audit completed; dry_run=${DRY_RUN}"
}

case "$COMMAND" in
  run) run_updates ;;
  check) run_updates ;;
  audit) audit_only ;;
  lockout-guard) lockout_guard ;;
  todo) [ -s "$ADVISORY_TODO_TEXT" ] && cat "$ADVISORY_TODO_TEXT" || printf 'No ZSEC advisory TODO file yet. Run: zsec check\n' ;;
  status) status ;;
  version) printf 'ZSEC Auto Updates %s\n' "$ZSEC_VERSION" ;;
  *)
    cat <<EOF
Usage: zsec [check|run|audit|lockout-guard|status|version]

check          Dry-run security update and audit
run            Apply security updates and hardening
audit          Run hardening/audit modules only
lockout-guard  Back up SSH config and record admin IP
todo           Show local advisory feed TODOs
status         Show timer and latest log
version        Print version
EOF
    exit 2
    ;;
esac
